GATEWAY_ADDR=:8080
DEFAULT_MODEL=honghu-local-demo

# Optional comma-separated tenant keys. Leave empty for local development.
GATEWAY_API_KEYS=

# Route simple tasks to local vLLM when available.
LOCAL_VLLM_URL=http://localhost:8000

# Generic OpenAI-compatible cloud provider.
OPENAI_COMPATIBLE_URL=
OPENAI_COMPATIBLE_API_KEY=

# DeepSeek provider. Set DEEPSEEK_API_KEY to enable it.
DEEPSEEK_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=

PROVIDER_TIMEOUT=60s
ENABLE_FAKE_PROVIDER=true
LOG_LEVEL=info
